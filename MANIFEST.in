# Ship the regression suite + helper scripts in the source distribution so
# anyone with the sdist can run `pytest` and reproduce the golden baseline.
# (Wheels still exclude tests/ — they're for development, not the installed lib.)
recursive-include tests *.py
recursive-include scripts *.py
recursive-include templates *.json *.md
recursive-include src/openflo/template_library *.json *.md
include CHANGELOG.md
include src/openflo/_golden.json
